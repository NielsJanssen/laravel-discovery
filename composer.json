{
  "name": "nielsjanssen/laravel-discovery",
  "description": "Laravel service provider and artisan command discovery powered by Tempest Discovery",
  "keywords": ["laravel", "discovery", "service-provider", "commands", "tempest"],
  "homepage": "https://github.com/NielsJanssen/laravel-discovery",
  "type": "library",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/NielsJanssen/laravel-discovery/issues",
    "source": "https://github.com/NielsJanssen/laravel-discovery"
  },
  "autoload": {
    "psr-4": {
      "NielsJanssen\\Laravel\\Discovery\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Factories\\": "workbench/database/factories/",
      "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
    }
  },
  "authors": [
    {
      "name": "Niels Janssen",
      "email": "hi@nielsjanssen.eu"
    }
  ],
  "require": {
    "php": "^8.5",
    "tempest/discovery": "^3.10"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "laravel/framework": "^13.11",
    "orchestra/testbench": "^11.1",
    "pestphp/pest": "4.6.*",
    "pestphp/pest-plugin-laravel": "^4.1",
    "laravel/pao": "^1.0"
  },
  "scripts": {
    "post-autoload-dump": [
      "@clear",
      "@prepare"
    ],
    "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "build": "@php vendor/bin/testbench workbench:build --ansi",
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@build",
      "@php vendor/bin/testbench serve --ansi"
    ],
    "lint": [
      "@php vendor/bin/pint --ansi"
    ],
    "test": "@php vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "NielsJanssen\\Laravel\\Discovery\\DiscoveryServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
